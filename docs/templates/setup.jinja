{% extends "base.jinja" %}
{% block title %}Setup{% endblock %}
{% block content %}

<h1>Setup</h1>

<h2>Prerequisites</h2>

<ul>
  <li>Python 3.11+</li>
  <li><a href="https://ollama.com/">Ollama</a> (recommended) or a <a href="https://aistudio.google.com/api-keys">Gemini API key</a></li>
</ul>

<h2>Install</h2>

<pre><code>git clone &lt;your-repo-url&gt; && cd amphib
python -m venv .venv && source .venv/bin/activate
pip install -r requirements.txt</code></pre>

<h2>Pull a model</h2>

<pre><code>ollama pull gemma3:4b      # balanced
ollama pull gemma3:12b     # more capable
ollama pull gemma3:1b      # lightweight</code></pre>

<h2>Configure</h2>

<pre><code>cp .env.example .env</code></pre>

<p>Edit <code>.env</code>:</p>

<table>
  <tr>
    <th>Variable</th>
    <th>Values</th>
    <th>Description</th>
  </tr>
  <tr>
    <td><code>LLM_PROVIDER</code></td>
    <td><code>ollama</code> or <code>gemini</code></td>
    <td>Backend choice</td>
  </tr>
  <tr>
    <td><code>DEFAULT_MODEL</code></td>
    <td>e.g. <code>gemma3:4b</code></td>
    <td>Model name</td>
  </tr>
  <tr>
    <td><code>GEMINI_API_KEY</code></td>
    <td>string</td>
    <td>Required for Gemini</td>
  </tr>
  <tr>
    <td><code>GITHUB_TOKEN</code></td>
    <td>string</td>
    <td>Optional — higher API rate limits</td>
  </tr>
</table>

<h2>Run</h2>

<pre><code>python score.py /path/to/resume.pdf</code></pre>

<p>That's it. Amphib will parse, enrich, and print a scored evaluation.</p>

{% endblock %}
